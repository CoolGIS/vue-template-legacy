{
  "name": "vue-template-legacy",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli .",
    "husky:install": "husky",
    "copy:arcgis-assets": "cpx \"node_modules/@arcgis/core/assets/**/*.*\" ./public/arcgis/assets",
    "prepare": "run-s husky:install copy:arcgis-assets"
  },
  "dependencies": {
    "@arcgis/core": "^4.34.8",
    "@tanstack/vue-query": "^5.92.9",
    "@vueuse/core": "^14.1.0",
    "element-plus": "^2.13.2",
    "ky": "^1.14.3",
    "lodash-es": "^4.17.23",
    "pinia": "^3.0.4",
    "vue": "^3.5.27",
    "vue-router": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.10.9",
    "@vitejs/plugin-legacy": "^7.2.1",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitejs/plugin-vue-jsx": "^5.1.3",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.1",
    "cpx2": "^8.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.42.0",
    "eslint-plugin-vue": "~10.7.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.2.7",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.42.0",
    "postcss-preset-env": "^11.1.2",
    "postcss-pxtorem": "^6.1.0",
    "prettier": "^3.8.1",
    "terser": "^5.46.0",
    "typescript": "~5.9.3",
    "unplugin-element-plus": "^0.11.2",
    "vite": "^7.3.1",
    "vite-bundle-analyzer": "^1.3.2",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vue-tsc": "^3.2.4"
  }
}
